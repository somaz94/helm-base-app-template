{
    "$schema": "http://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
        "replicaCount": {
            "type": "integer",
            "minimum": 1
        },
        "version": {
            "type": "string"
        },
        "environment": {
            "type": "string"
        },
        "image": {
            "type": "object",
            "properties": {
                "repository": { "type": "string" },
                "pullPolicy": {
                    "type": "string",
                    "enum": ["Always", "IfNotPresent", "Never"]
                },
                "tag": { "type": "string" }
            },
            "required": ["repository", "pullPolicy"]
        },
        "imagePullSecrets": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": { "type": "string" }
                },
                "required": ["name"]
            }
        },
        "nameOverride": { "type": "string" },
        "fullnameOverride": { "type": "string" },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "create": { "type": "boolean" },
                "automount": { "type": "boolean" },
                "annotations": { "type": "object" },
                "name": { "type": "string" }
            },
            "required": ["create"]
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "service": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
                },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
            },
            "required": ["type", "port"]
        },
        "ingress": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "className": { "type": "string" },
                "annotations": { "type": "object" },
                "hosts": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "host": { "type": "string" },
                            "paths": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "path": { "type": "string" },
                                        "pathType": {
                                            "type": "string",
                                            "enum": ["Exact", "Prefix", "ImplementationSpecific"]
                                        },
                                        "useAnnotation": { "type": "boolean" },
                                        "serviceName": { "type": "string" }
                                    },
                                    "required": ["path", "pathType"]
                                }
                            }
                        },
                        "required": ["host", "paths"]
                    }
                },
                "tls": { "type": "array" }
            }
        },
        "ingressReview": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "className": { "type": "string" },
                "annotations": { "type": "object" },
                "hosts": { "type": "array" },
                "clientVersion": { "type": "string" },
                "ruleNames": { "type": "array", "items": { "type": "string" } },
                "serviceNames": { "type": "array", "items": { "type": "string" } }
            }
        },
        "ingressHealth": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "className": { "type": "string" },
                "annotations": { "type": "object" },
                "hosts": { "type": "array" }
            }
        },
        "ingressApiDocs": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "className": { "type": "string" },
                "annotations": { "type": "object" },
                "hosts": { "type": "array" }
            }
        },
        "startupProbe": { "type": "object" },
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" },
        "resources": { "type": "object" },
        "strategy": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "config": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": ["RollingUpdate", "Recreate"]
                        },
                        "rollingUpdate": {
                            "type": "object",
                            "properties": {
                                "maxSurge": { "type": ["integer", "string"] },
                                "maxUnavailable": { "type": ["integer", "string"] }
                            }
                        }
                    }
                }
            }
        },
        "autoscaling": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "minReplicas": { "type": "integer", "minimum": 1 },
                "maxReplicas": { "type": "integer", "minimum": 1 },
                "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
                "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
        },
        "rbac": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" }
            }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": {
            "type": "array",
            "items": { "type": "object" }
        },
        "affinity": { "type": "object" },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "envConfig": { "type": "object" },
        "configs": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "items": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "datas": { "type": "object" }
                        },
                        "required": ["name", "datas"]
                    }
                }
            }
        },
        "volumes": {
            "type": "array",
            "items": { "type": "object" }
        },
        "volumeMounts": {
            "type": "array",
            "items": { "type": "object" }
        },
        "efs": {
            "type": "object",
            "properties": {
                "persistentVolumes": {
                    "type": "object",
                    "properties": {
                        "enabled": { "type": "boolean" },
                        "items": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": { "type": "string" },
                                    "fileSystemId": { "type": "string" },
                                    "accessPointId": { "type": "string" },
                                    "storage": { "type": "string" },
                                    "volumeMode": { "type": "string" },
                                    "accessModes": {
                                        "type": "array",
                                        "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"] }
                                    },
                                    "reclaimPolicy": {
                                        "type": "string",
                                        "enum": ["Retain", "Delete", "Recycle"]
                                    },
                                    "storageClassName": { "type": "string" }
                                },
                                "required": ["name", "fileSystemId", "storage", "accessModes", "storageClassName"]
                            }
                        }
                    }
                },
                "persistentVolumeClaims": {
                    "type": "object",
                    "properties": {
                        "enabled": { "type": "boolean" },
                        "items": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": { "type": "string" },
                                    "accessModes": {
                                        "type": "array",
                                        "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"] }
                                    },
                                    "storageClassName": { "type": "string" },
                                    "storage": { "type": "string" },
                                    "mountPath": { "type": "string" },
                                    "readOnly": { "type": "boolean" },
                                    "selector": {
                                        "type": "object",
                                        "properties": {
                                            "volumeName": { "type": "string" }
                                        }
                                    }
                                },
                                "required": ["name", "accessModes", "storageClassName", "storage", "mountPath"]
                            }
                        }
                    }
                }
            }
        }
    },
    "required": ["replicaCount", "image", "service"]
}
