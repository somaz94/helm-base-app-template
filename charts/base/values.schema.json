{
    "$schema": "http://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
        "replicaCount": {
            "type": "integer",
            "minimum": 1
        },
        "version": {
            "type": "string"
        },
        "environment": {
            "type": "string"
        },
        "image": {
            "type": "object",
            "properties": {
                "repository": { "type": "string" },
                "pullPolicy": {
                    "type": "string",
                    "enum": ["Always", "IfNotPresent", "Never"]
                },
                "tag": { "type": "string" }
            },
            "required": ["repository", "pullPolicy"]
        },
        "imageCredentials": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "registry": { "type": "string" },
                "username": { "type": "string" },
                "password": { "type": "string" },
                "name": { "type": "string" }
            }
        },
        "imagePullSecrets": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": { "type": "string" }
                },
                "required": ["name"]
            }
        },
        "nameOverride": { "type": "string" },
        "fullnameOverride": { "type": "string" },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "create": { "type": "boolean" },
                "automount": { "type": "boolean" },
                "annotations": { "type": "object" },
                "name": { "type": "string" }
            },
            "required": ["create"]
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "service": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
                },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
            },
            "required": ["type", "port"]
        },
        "ingress": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "className": { "type": "string" },
                "annotations": { "type": "object" },
                "hosts": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "host": { "type": "string" },
                            "paths": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "path": { "type": "string" },
                                        "pathType": {
                                            "type": "string",
                                            "enum": ["Exact", "Prefix", "ImplementationSpecific"]
                                        }
                                    },
                                    "required": ["path", "pathType"]
                                }
                            }
                        },
                        "required": ["host", "paths"]
                    }
                },
                "tls": { "type": "array" }
            }
        },
        "startupProbe": { "type": "object" },
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" },
        "resources": { "type": "object" },
        "strategy": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "config": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": ["RollingUpdate", "Recreate"]
                        },
                        "rollingUpdate": {
                            "type": "object",
                            "properties": {
                                "maxSurge": { "type": ["integer", "string"] },
                                "maxUnavailable": { "type": ["integer", "string"] }
                            }
                        }
                    }
                }
            }
        },
        "autoscaling": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "minReplicas": { "type": "integer", "minimum": 1 },
                "maxReplicas": { "type": "integer", "minimum": 1 },
                "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
                "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
        },
        "rbac": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "serviceAccountName": { "type": "string" }
            }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": {
            "type": "array",
            "items": { "type": "object" }
        },
        "affinity": { "type": "object" },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "envConfig": { "type": "object" },
        "configs": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "items": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "datas": { "type": "object" }
                        },
                        "required": ["name", "datas"]
                    }
                }
            }
        },
        "initContainers": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "items": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "image": { "type": "string" },
                            "imagePullPolicy": {
                                "type": "string",
                                "enum": ["Always", "IfNotPresent", "Never"]
                            },
                            "command": { "type": "array", "items": { "type": "string" } },
                            "args": { "type": "array", "items": { "type": "string" } },
                            "env": { "type": "array" },
                            "envFrom": { "type": "array" },
                            "volumeMounts": { "type": "array" },
                            "resources": { "type": "object" },
                            "securityContext": { "type": "object" }
                        },
                        "required": ["name", "image"]
                    }
                }
            }
        },
        "emptyDirVolumes": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "items": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "mountPath": { "type": "string" },
                            "readOnly": { "type": "boolean" },
                            "sizeLimit": { "type": "string" },
                            "medium": { "type": "string" }
                        },
                        "required": ["name", "mountPath"]
                    }
                }
            }
        },
        "persistentVolumes": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "items": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "storage": { "type": "string" },
                            "volumeMode": { "type": "string" },
                            "accessModes": {
                                "type": "array",
                                "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"] }
                            },
                            "reclaimPolicy": {
                                "type": "string",
                                "enum": ["Retain", "Delete", "Recycle"]
                            },
                            "storageClassName": { "type": "string" },
                            "path": { "type": "string" },
                            "server": { "type": "string" }
                        },
                        "required": ["name", "storage", "accessModes", "storageClassName", "path", "server"]
                    }
                }
            }
        },
        "persistentVolumeClaims": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "items": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "accessModes": {
                                "type": "array",
                                "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"] }
                            },
                            "storageClassName": { "type": "string" },
                            "storage": { "type": "string" },
                            "mountPath": { "type": "string" },
                            "selector": {
                                "type": "object",
                                "properties": {
                                    "volumeName": { "type": "string" }
                                }
                            }
                        },
                        "required": ["name", "accessModes", "storageClassName", "storage", "mountPath"]
                    }
                }
            }
        },
        "extraVolumes": { "type": "array" },
        "extraVolumeMounts": { "type": "array" },
        "certificate": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "secretName": { "type": "string" },
                "commonName": { "type": "string" },
                "duration": { "type": "string" },
                "renewBefore": { "type": "string" },
                "dnsNames": { "type": "array", "items": { "type": "string" } },
                "issuerName": { "type": "string" },
                "issuerKind": { "type": "string" }
            }
        },
        "certCleanup": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "CronJobName": { "type": "string" },
                "olderThanDays": { "type": "integer", "minimum": 1 },
                "YesterDays": { "type": "integer", "minimum": 1 }
            }
        }
    },
    "required": ["replicaCount", "image", "service"]
}
